<!DOCTYPE html>
<!-- 
  Dashboard de Entregas - Sistema de Monitoramento Logístico
  Exibe métricas de atrasos, gráficos comparativos e ranking de problemas operacionais
-->
<html lang="pt-BR">
<head>
<!-- Meta tags para configuração de caracteres e responsividade -->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Logístico</title>

<!-- Importação da biblioteca Chart.js para criar gráficos -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

/* Reset global: remove margens e preenchimentos padrão dos navegadores */
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

/* Configuração do corpo da página: cor de fundo e espaçamento */
body{
background:#174282;
padding:20px;
}

/* Estilo do título principal: espaçamento inferior e cor */
h1{
margin-bottom:20px;
color:#eff0f2;
}

/* Grid responsivo para os cards de métricas (Dashboard)*/
.dashboard{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:15px;
margin-bottom:20px;
}

/* Estilo dos cards: fundo branco, sombra e cantos arredondados */
.card{
background:white;
padding:20px;
border-radius:12px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

/* Estilo do subtítulo dos cards */
.card h3{
font-size:15px;
color:#666;
}

/* Estilo dos números grandes nos cards */
.card p{
font-size:28px;
font-weight:bold;
margin-top:10px;
}

/* Classe para cards de alerta (fundo vermelho claro) */
.alerta{
background:#ffebee;
border-left:6px solid #d32f2f;
}

/* Classe para cards de status bom (fundo verde claro) */
.bom{
background:#e8f5e9;
border-left:6px solid #2e7d32;
}

/* Grid para colocar gráficos lado a lado */
.graficos{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
margin-bottom:20px;
}

/* Estilo dos containers dos gráficos */
.grafico{
background:white;
padding:20px;
border-radius:12px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

/* Estilo do container de filtros */
.filtro{
background:white;
padding:15px;
border-radius:12px;
margin-bottom:20px;
}

/* Estilo da tabela: sem bordas, fundo branco */
table{
width:100%;
border-collapse:collapse;
background:white;
}

/* Estilo do cabeçalho da tabela: fundo escuro e texto branco */
th{
background:#010101;
color:rgb(255, 255, 255);
padding:10px;
}

/* Estilo das células da tabela */
td{
padding:10px;
text-align:center;
}

/* Zebra striping: alterna cores das linhas */
tr:nth-child(even){
background:#fcfcfc;
}

/* Destaque de linhas atrasadas */
.atrasada{
background:#fbff0089 !important;
font-weight:bold;
}

/* Destaque de linhas críticas (muito atrasadas) */
.critico{
background:#ed0909 !important;
color:rgb(255, 255, 255);
font-weight:bold;
}

/* Estilo do ranking de problemas */
.rank{
margin-top:20px;
background:white;
padding:20px;
border-radius:12px;
text-align:center;
display:flex;
flex-direction:column;
align-items:center;
}

/* Centraliza a lista ordenada do ranking */
.rank ol{
display:inline-block;
text-align:left;
}

</style>
</head>
<body>

<!-- Título principal do dashboard com ícone de pacote -->
<h1> Dashboard de Entregas- BUG DO MILÊNIO</h1>

<!-- Seção de cards com métricas principais -->
<div class="dashboard">

<!-- Card de alerta: mostra total de entregas atrasadas -->
<div class="card alerta">
<h3>Total de Entregas Atrasadas</h3>
<p id="atrasadas"></p>
</div>

<!-- Card: mostra total de todas as entregas -->
<div class="card">
<h3>Total de Entregas</h3>
<p id="total"></p>
</div>

<!-- Card: mostra a taxa percentual de atrasos -->
<div class="card">
<h3>Taxa de Atraso</h3>
<p id="taxa"></p>
</div>

<!-- Card de bom status: mostra qual entrega está mais crítica -->
<div class="card bom">
<h3>Entrega Mais Crítica</h3>
<p id="critica"></p>
</div>

</div>

<!-- Seção de filtro: permite selecionar uma transportadora específica -->
<div class="filtro">
<label><b>Filtrar Transportadora:</b></label>

<select id="filtroTransportadora">
<option value="Todos">Todos</option>
<option value="RotaMax">RotaMax</option>
<option value="ViaCargo">ViaCargo</option>
<option value="FlashLog">FlashLog</option>
</select>
</div>

<!-- Tabela detalhada: lista todas as entregas com seus dados -->
<table>
<thead>
<tr>
<th>ID</th>
<th>Transportadora</th>
<th>Região</th>
<th>Prazo</th>
<th>Dias Reais</th>
<th>Status</th>
</tr>
</thead>

<!-- Corpo da tabela: preenchido dinamicamente por JavaScript -->
<tbody id="tabela"></tbody>

</table>

<!-- Seção de ranking: mostra as transportadoras com mais dias acumulados de atraso -->
<div class="rank">
<h2> Ranking de Problemas Operacionais</h2>
<ol id="ranking"></ol>
</div>

<br>

<!-- Seção de gráficos: exibe comparações visuais de dados -->
<div class="graficos">

<!-- Gráfico de barras: mostra atrasos por transportadora -->
<div class="grafico">
<canvas id="graficoTransportadora"></canvas>
</div>

<!-- Gráfico de pizza: mostra distribuição de atrasos por região -->
<div class="grafico">
<canvas id="graficoRegiao"></canvas>
</div>

</div>

<!-- Seção JavaScript: contém toda a lógica de processamento de dados -->
<script>

/* ========== DADOS ========== */
/* Array com todas as entregas: cada objeto contém ID, transportadora, região, prazo e dias reais */
const dados = [

{id:301,transportadora:"RotaMax",regiao:"Sudeste",prazo:3,reais:7},
{id:302,transportadora:"ViaCargo",regiao:"Sul",prazo:5,reais:5},
{id:303,transportadora:"FlashLog",regiao:"Nordeste",prazo:4,reais:9},
{id:304,transportadora:"RotaMax",regiao:"Norte",prazo:6,reais:4},
{id:305,transportadora:"ViaCargo",regiao:"Centro-Oeste",prazo:2,reais:6},
{id:306,transportadora:"FlashLog",regiao:"Sul",prazo:5,reais:12},
{id:307,transportadora:"RotaMax",regiao:"Sul",prazo:6,reais:9},
{id:308,transportadora:"ViaCargo",regiao:"Sudeste",prazo:3,reais:4},
{id:309,transportadora:"FlashLog",regiao:"Norte",prazo:5,reais:5},
{id:310,transportadora:"ViaCargo",regiao:"Nordeste",prazo:4,reais:8}

];

/* ========== PROCESSAMENTO DE DADOS ========== */
/* Para cada entrega, calcula o atraso e determina o status */
dados.forEach(item=>{
item.atraso = item.reais - item.prazo; // Diferença entre dias reais e prazo
item.status = item.reais > item.prazo ? "Atrasada" : "No Prazo"; // Define status
});

/* ========== CÁLCULOS DE MÉTRICAS ========== */
/* Filtra apenas as entregas atrasadas */
const atrasadas = dados.filter(x=>x.status==="Atrasada");

/* Exibe na página o total de entregas atrasadas */
document.getElementById("atrasadas").innerHTML =
atrasadas.length;

/* Exibe na página o total de entregas */
document.getElementById("total").innerHTML =
dados.length;

/* Calcula e exibe a taxa de atraso em percentual */
document.getElementById("taxa").innerHTML =
((atrasadas.length/dados.length)*100).toFixed(1)+"%";

/* Encontra a entrega com maior atraso (mais crítica) */
let critica =
dados.sort((a,b)=>b.atraso-a.atraso)[0];

/* Exibe na página a informação da entrega mais crítica */
document.getElementById("critica").innerHTML =
"ID "+critica.id+" ("+critica.atraso+" dias)";

/* ========== FUNÇÃO PARA CARREGAR TABELA ========== */
/* Função que preenche a tabela dinamicamente com dados filtrados */
function carregarTabela(filtro="Todos"){

let tabela = document.getElementById("tabela");
tabela.innerHTML=""; // Limpa a tabela antes de preencher

dados
.filter(d=> filtro==="Todos" || d.transportadora===filtro) // Aplica filtro
.forEach(item=>{

let classe=""; // Variável para definir a cor da linha

/* Define a cor de destaque conforme a severidade do atraso */
if(item.atraso>=5){
classe="critico"; // Vermelho intenso se atraso >= 5 dias
}
else if(item.status==="Atrasada"){
classe="atrasada"; // Vermelho claro se atrasada mas < 5 dias
}

/* Insere uma linha na tabela com os dados da entrega */
tabela.innerHTML += `
<tr class="${classe}">
<td>${item.id}</td>
<td>${item.transportadora}</td>
<td>${item.regiao}</td>
<td>${item.prazo}</td>
<td>${item.reais}</td>
<td>${item.status}</td>
</tr>
`;

});
}

/* Carrega a tabela inicial sem filtros */
carregarTabela();

/* ========== FILTRO DE TRANSPORTADORA ========== */
/* Listener para quando o usuário muda o filtro de transportadora */
document
.getElementById("filtroTransportadora")
.addEventListener("change",(e)=>{
carregarTabela(e.target.value); // Recarrega tabela com novo filtro
});

/* ========== GRÁFICO DE TRANSPORTADORAS ========== */
/* Array com nomes das transportadoras */
const transportadoras = ["RotaMax","ViaCargo","FlashLog"];

/* Conta quantas entregas estão atrasadas para cada transportadora */
const atrasosTransportadora =
transportadoras.map(t=>
dados.filter(x=>
x.transportadora===t &&
x.status==="Atrasada"
).length
);

/* Cria gráfico de barras mostrando atrasos por transportadora */
new Chart(
document.getElementById("graficoTransportadora"),
{
    type:"bar",
    data:{
        labels:transportadoras,
        datasets:[{
            label:"Entregas Atrasadas",
            data:atrasosTransportadora
        }]
    },
    options:{
        scales:{
            y:{
                beginAtZero:true,
                max:7, // valor máximo do eixo
                ticks:{
                    stepSize:1 // intervalo entre números
                }
            }
        }
    }
});

/* ========== GRÁFICO DE REGIÕES ========== */
/* Extrai todas as regiões únicas dos dados */
const regioes = [...new Set(dados.map(x=>x.regiao))];

/* Conta quantas entregas estão atrasadas para cada região */
const atrasosRegiao =
regioes.map(r=>
dados.filter(x=>
x.regiao===r &&
x.status==="Atrasada"
).length
);

/* Cria gráfico de pizza mostrando distribuição de atrasos por região */
new Chart(
document.getElementById("graficoRegiao"),
{
type:"pie", // Tipo: gráfico de pizza
data:{
labels:regioes, // Nomes das regiões
datasets:[{
data:atrasosRegiao // Dados de atrasos
}]
}
}
);

/* ========== RANKING DE TRANSPORTADORAS ========== */
/* Elemento onde o ranking será exibido */
let ranking = document.getElementById("ranking");

/* Calcula o total de dias de atraso para cada transportadora */
const rankingDados =
transportadoras
.map(t=>{

let total =
dados.filter(x=>x.transportadora===t) // Filtra por transportadora
.reduce((s,x)=>s+x.atraso,0); // Soma todos os atrasos

return {
transportadora:t,
atraso:total
};

})
.sort((a,b)=>b.atraso-a.atraso); // Ordena por atraso decrescente

/* Exibe cada transportadora no ranking com seu total de dias de atraso */
rankingDados.forEach(item=>{

ranking.innerHTML += `
<li>
${item.transportadora}
- ${item.atraso} dias acumulados de atraso
</li>
`;

});

</script>

</body>
</html>